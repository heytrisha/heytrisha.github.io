{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": true,
  "default_agent": "plan",

  // === Permissions ===
  "permission": {
    "bash": {
      "sudo *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      ":(){:|:&};:": "deny" // fork bomb, just in case
    }
  },

  // === Agent Overrides ===
  "agent": {
    "plan": {
      "model": "opencode-go/kimi-k2.6"
    },
    "build": {
      "model": "opencode-go/minimax-m2.7",
      "permission": {
        "bash": "ask"
      }
    }
  },

  // === Experimental ===
  "experimental": {
    "disable_paste_summary": true
  }
}