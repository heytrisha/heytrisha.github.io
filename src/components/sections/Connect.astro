---
import { site } from '@/data/site';
---

<section id="connect" class="px-6 py-24">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Connect</h2>
    <p class="mt-3 text-muted-foreground">
      Let's build something great together
    </p>

    <a
      href={`mailto:${site.email}`}
      class="mt-8 inline-flex h-12 items-center justify-center rounded-lg bg-primary px-8 text-base font-medium text-primary-foreground transition-colors hover:bg-primary/90"
    >
      Say hello
    </a>

    <div class="mt-10 flex items-center justify-center gap-6">
      {site.socials.github && (
        <a
          href={site.socials.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground transition-colors hover:text-foreground"
        >
          GitHub
        </a>
      )}
      {site.socials.linkedin && (
        <a
          href={site.socials.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground transition-colors hover:text-foreground"
        >
          LinkedIn
        </a>
      )}
      {site.socials.behance && (
        <a
          href={site.socials.behance}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground transition-colors hover:text-foreground"
        >
          Behance
        </a>
      )}
    </div>
  </div>
</section>
