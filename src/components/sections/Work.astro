---
import { getCollection } from 'astro:content';
import ProjectCard from '@/components/projects/ProjectCard.astro';

const basePath = import.meta.env.BASE_PATH || '';
let projects: Awaited<ReturnType<typeof getCollection<'projects'>>> = [];
try {
  projects = await getCollection('projects');
  projects = projects.filter((p) => p.data.featured);
  projects.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
} catch {
  // No projects yet
}
---

<section id="work" class="py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mb-16 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Work</h2>
      <p class="mt-3 text-muted-foreground">
        Selected projects and case studies
      </p>
    </div>
  </div>

  {projects.length > 0 ? (
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {projects.map((project, index) => (
          <ProjectCard project={project} index={index} basePath={basePath} />
        ))}
      </div>
    </div>
  ) : (
    <div class="mx-auto max-w-6xl px-6">
      <div class="rounded-xl border border-foreground/10 bg-card p-12 text-center">
        <p class="text-muted-foreground">Work coming soon</p>
      </div>
    </div>
  )}
</section>
