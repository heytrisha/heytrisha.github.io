---
const highlights = [
  {
    emoji: '🎨',
    title: 'Design Enthusiast',
    description: 'Passionate about creating interfaces that balance beauty with usability.',
  },
  {
    emoji: '🌱',
    title: 'Continuous Learner',
    description: 'Always exploring new tools, techniques, and perspectives in design and tech.',
  },
  {
    emoji: '🤝',
    title: 'Collaborative Spirit',
    description: 'I thrive in cross-functional teams where design and engineering intersect.',
  },
];
---

<section id="life" class="px-6 py-24">
  <div class="mx-auto max-w-6xl">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Life</h2>
      <p class="mt-3 text-muted-foreground">
        Beyond the pixels
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-3">
      {highlights.map((item) => (
        <div class="rounded-xl border border-foreground/10 bg-card p-6 text-center">
          <div class="text-3xl">{item.emoji}</div>
          <h3 class="mt-4 text-lg font-semibold">{item.title}</h3>
          <p class="mt-2 text-sm text-muted-foreground">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
