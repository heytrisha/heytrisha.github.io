---
import { effects } from '@/data/effects';

const hoverClass = effects.skillHoverScale ? 'skill-hover' : '';
---
<section id="skills" class="px-6 py-24">
  <div class="mx-auto max-w-4xl">
    <div class="mb-12 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Skills</h2>
      <p class="mt-3 text-muted-foreground">
        Tools and techniques I work with
      </p>
    </div>

    <div class="skills-content overflow-visible">
      <p class="text-center text-xl font-bold leading-relaxed text-[var(--color-muted-foreground)]/40 lg:text-2xl">
        I design with{' '}
        <span class={`skill ${hoverClass}`}>Figma</span>,{' '}
        <span class={`skill ${hoverClass}`}>Framer</span>,{' '}and{' '}
        <span class={`skill ${hoverClass}`}>Adobe Creative Suite</span>.{' '}
        I build{' '}
        <span class={`skill ${hoverClass}`}>Design Systems</span>, prototype with{' '}
        <span class={`skill ${hoverClass}`}>Prototyping</span>,{' '}and care deeply about{' '}
        <span class={`skill ${hoverClass}`}>Accessibility</span>{' '}and{' '}
        <span class={`skill ${hoverClass}`}>User Research</span>.{' '}
        I work with{' '}
        <span class={`skill ${hoverClass}`}>React</span>,{' '}
        <span class={`skill ${hoverClass}`}>Astro</span>,{' '}and{' '}
        <span class={`skill ${hoverClass}`}>Tailwind CSS</span>{' '}to bring ideas to life.
      </p>
    </div>
  </div>
</section>

<script>
  const el = document.querySelector('.skills-content') as HTMLElement | null;
  if (el) {
    el.style.height = el.offsetHeight + 'px';
  }
</script>

<style>
  .skill {
    color: var(--color-foreground);
    display: inline-block;
    border-radius: 0.2em;
    cursor: default;
  }
  .skill-hover {
    transition: padding 0.3s cubic-bezier(0.23, 1, 0.32, 1),
                transform 0.3s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .skill-hover:hover {
    padding: 0.05em 0.4em;
    transform: scale(1.08);
  }
</style>
