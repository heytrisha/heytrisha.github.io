---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  index: number;
  basePath: string;
}

const { project, index, basePath } = Astro.props;
const projectNumber = String(index + 1).padStart(2, '0');

const colors = [
  '#5eead4', // teal
  '#c4b5fd', // violet
  '#fdba74', // orange
  '#f9a8d4', // pink
  '#7dd3fc', // sky
  '#86efac', // green
];
const color = colors[index % colors.length];

// Dynamically import all images from assets
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{png,jpg,jpeg,webp}', { eager: true });
const imagePath = '/src/assets/images/' + project.data.thumbnail.split('/').pop();
const imageModule = images[imagePath];
---

<a
  href={`${basePath}/projects/${project.id}`}
  class="group relative block aspect-[3/4] overflow-hidden rounded-lg"
>
  <!-- Background image: grayscale by default, full color on hover -->
  {imageModule ? (
    <Image
      src={imageModule.default}
      alt={project.data.title}
      width={800}
      class="absolute inset-0 size-full scale-[1.1] object-cover grayscale transition-all duration-700 ease-out group-hover:grayscale-0"
    />
  ) : (
    <div class="absolute inset-0 bg-muted" />
  )}

  <!-- Neon color tint blended into the image -->
  <div
    class="pointer-events-none absolute inset-0 mix-blend-overlay opacity-100 transition-opacity duration-700 group-hover:opacity-0"
    style={`background: linear-gradient(to top, ${color} 0%, ${color} 6%, transparent 20%);`}
  />

  <!-- Dark gradient for text legibility -->
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent" />

  <!-- Text at bottom-left -->
  <div class="absolute bottom-6 left-6">
    <span class="text-sm font-medium" style={`color: ${color};`}>
      {projectNumber}
    </span>
    <h3 class="mt-1 text-xl font-semibold tracking-tight text-white">
      {project.data.title}
    </h3>
  </div>
</a>
