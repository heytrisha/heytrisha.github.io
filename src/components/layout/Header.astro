---
import { site } from '@/data/site';
import { MobileMenu } from './MobileMenu';

const basePath = import.meta.env.BASE_PATH || '';

const navLinks = [
  { label: 'Work', href: `${basePath}/#work` },
  { label: 'Skills', href: `${basePath}/#skills` },
  { label: 'Life', href: `${basePath}/#life` },
];
---

<header class="fixed top-0 right-0 left-0 z-40 border-b border-foreground/10 bg-background/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a href={basePath || '/'} class="text-lg font-semibold tracking-tight lowercase">
      {site.firstName}
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="rounded-lg px-3 py-2 text-sm font-medium text-foreground/70 lowercase transition-colors hover:text-foreground"
        >
          {link.label}
        </a>
      ))}
      <a
        href={`${basePath}/resume.pdf`}
        download={site.resumeDownloadName}
        class="ml-2 rounded-lg px-3 py-2 text-sm font-medium text-foreground/70 lowercase transition-colors hover:text-foreground"
      >
        Resume
      </a>
    </nav>

    <!-- Mobile menu -->
    <MobileMenu client:load links={navLinks} basePath={basePath} />
  </div>
</header>
