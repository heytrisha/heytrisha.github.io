---
import Layout from '@/layouts/Layout.astro';
import MotionPlayground from './components/MotionPlayground.tsx';
import './styles/playground.css';
---

<Layout title="Motion Playground">
  <div class="px-6 py-12">
    <div class="mx-auto max-w-5xl">
      <header class="mb-12">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
          Motion Playground
        </h1>
        <p class="mt-4 text-lg text-muted-foreground">
          A self-contained demo showcasing Motion One capabilities — stagger,
          spring, drag, scroll parallax, and orchestrated sequences.
        </p>
      </header>

      <MotionPlayground client:visible />
    </div>
  </div>
</Layout>
